## SECTION=wago_specific_paramprovider

config PP_PROFIBUS
  bool
  select HOST_CT_BUILD
  select GOOGLETEST
  select WDX_CORE
  select WDX_CORE_TEST_LIB
	select WDX_LINUX
  select WDX_LINUX_CLIENT_LIB
  select WDX_WDM
  select WDX_WDM_CPP_HEADERS
  select GLIB
  select LIBDPS
  prompt "pp_profibus"
  help
    Enable Profibus parameter provider
