-    bld.SAMBA_BINARY(
-        'test_tstream',
-        source='tests/test_tstream.c tests/socketpair_tcp.c',
-        deps='cmocka replace LIBTSOCKET',
-        local_include=False,
-        enabled=bld.CONFIG_SET('HAVE_TCP_USER_TIMEOUT'),
